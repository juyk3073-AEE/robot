<?xml version="1.0"?>
<robot name="robot_2leg_wheel">

  <link name="base_link">
    <visual>
      <geometry><box size="0.2 0.3 0.1"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.2 0.3 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.03"/>
    </inertial>
  </link>

  <joint name="hip_left_joint" type="revolute">
    <parent link="base_link"/>
    <child link="thigh_left"/>
    <origin xyz="0 0.18 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="50.0" velocity="5.0"/>
  </joint>

  <link name="thigh_left">
    <visual>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 -0.15"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="knee_left_joint" type="revolute">
    <parent link="thigh_left"/>
    <child link="calf_left"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="0.0" effort="50.0" velocity="5.0"/>
  </joint>

  <link name="calf_left">
    <visual>
      <geometry><cylinder radius="0.025" length="0.3"/></geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="red"><color rgba="0.8 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.025" length="0.3"/></geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 -0.15"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="calf_left"/>
    <child link="wheel_left"/>
    <origin xyz="0 0.05 -0.3" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/> <limit effort="15.0" velocity="30.0"/>
  </joint>

  <link name="wheel_left">
    <visual>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>


  <joint name="hip_right_joint" type="revolute">
    <parent link="base_link"/>
    <child link="thigh_right"/>
    <origin xyz="0 -0.18 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="50.0" velocity="5.0"/>
  </joint>

  <link name="thigh_right">
    <visual>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.03" length="0.3"/></geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 -0.15"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="knee_right_joint" type="revolute">
    <parent link="thigh_right"/>
    <child link="calf_right"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="0.0" effort="50.0" velocity="5.0"/>
  </joint>

  <link name="calf_right">
    <visual>
      <geometry><cylinder radius="0.025" length="0.3"/></geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="blue"><color rgba="0 0 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.025" length="0.3"/></geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 -0.15"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="calf_right"/>
    <child link="wheel_right"/>
    <origin xyz="0 -0.05 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="15.0" velocity="30.0"/>
  </joint>

  <link name="wheel_right">
    <visual>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

</robot>